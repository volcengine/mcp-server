{
 "components": {
  "schemas": {
   "AllowListObject": {
    "description": "白名单详情",
    "properties": {
     "AllowListDesc": {
      "description": "白名单描述。",
      "example": "for-test",
      "type": "string"
     },
     "AllowListIPNum": {
      "description": "白名单中的 IP 数量。",
      "example": 2,
      "format": "int64",
      "type": "integer"
     },
     "AllowListId": {
      "description": "白名单 ID。",
      "example": "acl-90c721ca3f1648e7b9803xxxxxxx",
      "type": "string"
     },
     "AllowListName": {
      "description": "白名单名称。",
      "example": "testlist",
      "type": "string"
     },
     "AllowListType": {
      "description": "白名单类型。默认为 IPv4，表示允许白名单中的 IPv4 地址访问。",
      "example": "IPv4",
      "type": "string"
     },
     "AssociatedInstanceNum": {
      "description": "该白名单已绑定的实例个数。",
      "example": 1,
      "format": "int64",
      "type": "integer"
     }
    },
    "required": [
     "AllowListId",
     "AllowListDesc",
     "AllowListName",
     "AllowListType",
     "AllowListIPNum",
     "AssociatedInstanceNum"
    ],
    "type": "object"
   },
   "AssociatedInstanceInfo": {
    "description": "白名单绑定的完整的实例列表",
    "properties": {
     "InstanceId": {
      "description": "实例 ID。",
      "example": "rabbitmq-cnoexxxxx",
      "type": "string"
     },
     "InstanceName": {
      "description": "实例名称。",
      "example": "test",
      "type": "string"
     },
     "VPC": {
      "description": "实例所属 VPC 的 ID。",
      "example": "vpc-3ret6bva9k54wxxxxx",
      "type": "string"
     }
    },
    "required": [
     "InstanceId",
     "InstanceName",
     "VPC"
    ],
    "type": "object"
   },
   "BasicInstanceInfoObject": {
    "description": "实例的基本信息，包括实例名称、ID 等信息。",
    "properties": {
     "AccountId": {
      "description": "创建实例的火山引擎主账号 ID。",
      "example": "20000",
      "type": "string"
     },
     "ApplyPrivateDNSToPublic": {
      "description": "是否已开启公网解析功能。\n- true：已开启\n- false：已关闭",
      "example": true,
      "type": "boolean"
     },
     "ArchType": {
      "description": "实例的类型，即集群版或单机版。\n- SingleNode：单机版\n- Cluster：集群版",
      "example": "Cluster",
      "type": "string"
     },
     "ChargeDetail": {
      "$ref": "#/components/schemas/ChargeDetailObject"
     },
     "ComputeSpec": {
      "description": "RabbitMQ 实例的计算规格。\n可以通过 DescribeComputeSpecsInfo 接口查询指定可用区售卖中的计算规格。",
      "example": "rabbitmq.n3.x2.medium",
      "type": "string"
     },
     "CreateTime": {
      "description": "实例的创建时间。时间显示格式为 YYYY-MM-DD'T'HH:MM:SS'Z'。",
      "example": "1654485759",
      "type": "string"
     },
     "EipId": {
      "description": "EIP 的 ID。如果实例未开启公网访问方式，则不返回此参数。",
      "example": "eip-mjhulvqza6805smt1bnc****",
      "type": "string"
     },
     "InitUserName": {
      "description": "RabbitMQ WebUI 管理员账号名。",
      "example": "Admin",
      "type": "string"
     },
     "InstanceDescription": {
      "description": "实例的简单描述。",
      "example": "这是一个测试实例",
      "type": "string"
     },
     "InstanceId": {
      "description": "RabbitMQ 实例 ID。",
      "example": "rabbitmq-cnngqkfgdudt****",
      "type": "string"
     },
     "InstanceName": {
      "description": "RabbitMQ 实例名称。",
      "example": "RabbitMQinstance",
      "type": "string"
     },
     "InstanceStatus": {
      "description": "实例状态。",
      "example": "Running",
      "type": "string"
     },
     "IsEncrypted": {
      "description": "是否开启了云盘加密。\n- 云盘加密为邀测功能，如需使用，请联系技术支持申请白名单。\n- 仅 DescribeInstanceDetail 接口返回此字段。",
      "example": false,
      "type": "boolean"
     },
     "ProjectName": {
      "description": "实例所属的 IAM 项目。如果实例不属于任何 IAM 项目，则不返回此参数。",
      "example": "newproject",
      "type": "string"
     },
     "RegionDescription": {
      "description": "地域的描述信息。",
      "example": "华南1（广州）",
      "type": "string"
     },
     "RegionId": {
      "description": "实例所在的地域 ID。",
      "example": "cn-guangzhou",
      "type": "string"
     },
     "StorageSpace": {
      "description": "实例总存储空间，单位为 GiB。",
      "example": 200,
      "format": "int32",
      "type": "integer"
     },
     "SubnetId": {
      "description": "VPC 的子网 ID。",
      "example": "subnet-min6uy01kuf45smt1a2i****",
      "type": "string"
     },
     "TagMap": {
      "$ref": "#/components/schemas/Tags"
     },
     "Tags": {
      "description": "实例绑定的标签。",
      "example": [
       "/"
      ],
      "items": {
       "$ref": "#/components/schemas/TagObject"
      },
      "type": "array"
     },
     "UsedStorageSpace": {
      "description": "实例已用储空间。单位为 GiB。",
      "example": 100,
      "format": "int32",
      "type": "integer"
     },
     "Version": {
      "description": "支持的 RabbitMQ 版本。当前支持的版本包括：\n- 3.8.18：RabbitMQ 3.8.18 版本。",
      "example": "3.8.18",
      "type": "string"
     },
     "VpcId": {
      "description": "私有网络（VPC） ID。",
      "example": "vpc-13fo9gkz6j6683n6nu5ec****",
      "type": "string"
     },
     "ZoneDescription": {
      "description": "可用区的描述信息",
      "example": "华南1（广州）-可用区B",
      "type": "string"
     },
     "ZoneId": {
      "description": "实例所在的可用区 ID。对于跨 AZ 的高可用实例，此处会返回多个可用区 ID。",
      "example": "cn-guangzhou-a",
      "type": "string"
     }
    },
    "required": [
     "InstanceDescription",
     "InstanceStatus",
     "InstanceName",
     "UsedStorageSpace",
     "StorageSpace",
     "InstanceId",
     "RegionId",
     "Version",
     "ZoneId",
     "RegionDescription",
     "ChargeDetail",
     "ArchType",
     "ComputeSpec",
     "CreateTime"
    ],
    "type": "object"
   },
   "BasicPluginInfoObject": {
    "description": "该实例的插件信息，包括支持的插件列表、每个插件的开启状态等。",
    "properties": {
     "Description": {
      "description": "插件的描述信息。",
      "example": "支持 MQTT 协议（TCP方式）",
      "type": "string"
     },
     "DisablePrompt": {
      "description": "关闭此插件的注意事项说明。",
      "example": "禁用该插件将触发RabbitMQ集群滚动重启",
      "type": "string"
     },
     "EnablePrompt": {
      "description": "开启此插件的注意事项说明。",
      "example": "启用该插件将触发RabbitMQ集群滚动重启",
      "type": "string"
     },
     "Enabled": {
      "description": "是否已开启插件。\n- true：插件已开启。\n- false：插件已关闭。",
      "example": true,
      "type": "boolean"
     },
     "NeedRebootOnChange": {
      "description": "开启或关闭插件是否会引发 RabbitMQ 实例重启。\n- true：会重启实例。\n- false：不会重启实例。",
      "example": true,
      "type": "boolean"
     },
     "PluginName": {
      "description": "插件名称。",
      "example": "rabbitmq_mqtt",
      "type": "string"
     },
     "Port": {
      "description": "插件的服务端口。",
      "example": 8883,
      "format": "int32",
      "type": "integer"
     },
     "Version": {
      "description": "插件版本。",
      "example": "3.8.18",
      "type": "string"
     }
    },
    "required": [
     "PluginName",
     "Version",
     "NeedRebootOnChange",
     "Enabled",
     "Port",
     "Description"
    ],
    "type": "object"
   },
   "ChargeDetailObject": {
    "description": "实例的计费信息，包括计费方式等信息。",
    "properties": {
     "AutoRenew": {
      "description": "包年包月实例到期后是否自动续费。\n- true：自动续费。\n- false：不自动续费。到期后需要手动续费，否则实例将被关停。",
      "example": true,
      "type": "boolean"
     },
     "ChargeEndTime": {
      "description": "实例的结束计费时间，时间显示格式为 YYYY-MM-DD'T'HH:MM:SS'Z'。",
      "example": "2022-01-02T15:04:05Z07:00",
      "type": "string"
     },
     "ChargeExpireTime": {
      "description": "包年包月实例的到期时间。时间显示格式为 YYYY-MM-DD'T'HH:MM:SS'Z'。\n仅包年包月实例返回此参数。",
      "example": "2022-01-02T15:04:05Z07:00",
      "type": "string"
     },
     "ChargeStartTime": {
      "description": "实例的开始计费时间，时间显示格式为 YYYY-MM-DD'T'HH:MM:SS'Z'。",
      "example": "2022-01-02T15:04:05Z07:00",
      "type": "string"
     },
     "ChargeStatus": {
      "description": "实例的计费状态。包括：\n- Normal：正常\n- Overdue：按量计费欠费\n- Expired：包年包月到期",
      "example": "Normal",
      "type": "string"
     },
     "ChargeType": {
      "description": "实例的计费类型。支持的类型包括：\n- PostPaid ：按量付费\n- PrePaid：包年包月",
      "example": "PostPaid",
      "type": "string"
     },
     "OverdueReclaimTime": {
      "description": "实例欠费关停后的预计释放时间。时间显示格式为 YYYY-MM-DD'T'HH:MM:SS'Z'。",
      "example": "2022-01-02T15:04:05Z07:00",
      "type": "string"
     },
     "OverdueTime": {
      "description": "实例的欠费关停时间。时间显示格式为 YYYY-MM-DD'T'HH:MM:SS'Z'。",
      "example": "2022-01-02T15:04:05Z07:00",
      "type": "string"
     }
    },
    "required": [
     "ChargeType",
     "ChargeStatus"
    ],
    "type": "object"
   },
   "ChargeInfoObject": {
    "description": "RabbitMQ实例的计费类型等计费信息。",
    "properties": {
     "AutoRenew": {
      "description": "包年包月实例到期后是否自动续费。\n- true：自动续费。\n- false：不自动续费。到期后需要手动续费，否则实例将被关停。\n仅包年包月类型的实例需要指定，即 ChargeType 指定为 PrePaid 时必选。",
      "example": false,
      "type": "boolean"
     },
     "ChargeType": {
      "description": "实例的计费类型。支持的类型包括：\n- PostPaid ：按量付费\n- PrePaid：包年包月\n指定为 PrePaid 时，应同时指定 AutoRenew、PeriodUnit 和 Period 参数。",
      "example": "PostPaid",
      "type": "string"
     },
     "Period": {
      "description": "包年包月类型实例的购买时长。\n- PeriodUnit 指定为 Month 时，取值范围为 1~9。\n- PeriodUnit 指定为 Year 时，取值范围为 1~3。\n仅包年包月类型的实例需要指定，即 ChargeType 指定为 PrePaid 时必选。",
      "example": 1,
      "format": "int32",
      "type": "integer"
     },
     "PeriodUnit": {
      "description": "包年包月类型实例的生命周期单位，即指定以月或以年为单位购买。支持设置为：\n- Month：包月\n- Year：包年\n仅包年包月类型的实例需要指定，即 ChargeType 指定为 PrePaid 时必选。",
      "example": "Month",
      "type": "string"
     }
    },
    "required": [
     "ChargeType"
    ],
    "type": "object"
   },
   "ChargeItemPriceObject": {
    "description": "计费单元",
    "properties": {
     "ChargeItemCode": {
