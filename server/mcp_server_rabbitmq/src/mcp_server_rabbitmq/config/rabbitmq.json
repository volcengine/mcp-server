   "EndpointObject": {
    "description": "实例的接入点列表。\n被以下接口引用：\n- DescribeInstanceDetail",
    "properties": {
     "EndpointType": {
      "description": "实例的接入点类型。关于接入点的详细说明请参考[查看接入点](https://www.volcengine.com/docs/6439/122806)。\nRabbitMQ实例提供的接入点类型包括：\n- WEB：Web UI 接入点\n- AMQP0_9_1：AMQP 接入点\n- MQTT：MQTT接入点\n- WEB_MQTT：WEB MQTT 接入点\n- STOMP：STOMP 接入点",
      "example": "WEB",
      "type": "string"
     },
     "InternalEndpoint": {
      "description": "实例的私网访问域名。",
      "example": "<INTERNAL_ENDPOINT>:5672",
      "type": "string"
     },
     "InternalIpEndpoint": {
      "description": "公共服务区 IP 接入点。",
      "example": "<INTERNAL_IP_ENDPOINT>:5672",
      "type": "string"
     },
     "NetworkType": {
      "description": "接入点的网络类型。PrivateNetwork 表示私有网络 VPC。",
      "example": "PrivateNetwork",
      "type": "string"
     },
     "PublicEndpoint": {
      "description": "实例公网访问域名。仅在开启公网访问之后显示。",
      "example": "rbtmq-322db6ab****.rabbitmq.volces.com:5671",
      "type": "string"
     }
    },
    "required": [
     "EndpointType",
     "NetworkType"
    ],
    "type": "object"
   },
