   "OperationEvent": {
    "description": "OperationEvent",
    "properties": {
     "Duration": {
      "description": "后台任务的总耗时，单位为秒。",
      "example": 10,
      "format": "int32",
      "type": "integer"
     },
     "EndTime": {
